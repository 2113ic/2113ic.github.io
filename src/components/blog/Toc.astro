---
import type { MarkdownHeading } from 'astro'

interface TocItem extends MarkdownHeading {
  children: TocItem[]
}

const { data } = Astro.props
const tocs = genMarkdownToc(data)

function genMarkdownToc(headings: MarkdownHeading[]) {
  const shallowHeadings = headings.filter(({ depth }) => depth > 1 && depth < 4)
  const addToToc = (toc: TocItem[], heading: MarkdownHeading) => {
    const lastItem = toc[toc.length - 1]

    if (!lastItem || heading.depth === lastItem.depth) {
      toc.push({ ...heading, children: [] })
    } else if (heading.depth > lastItem.depth) {
      addToToc(lastItem.children, heading)
    }
  }

  const toc: TocItem[] = []
  for (const heading of shallowHeadings) {
    addToToc(toc, heading)
  }

  return toc
}
---

{/* Desktop TOC — fixed sidebar in right margin */}
<nav class="toc-desktop">
  <p class="toc-desktop__title">目录</p>
  <ul class="toc-list">
    {
      tocs.map((parent) => (
        <li class="toc-item">
          <a href={'#'.concat(parent.slug)}>{parent.text}</a>
          {parent.children.length > 0 && (
            <ul class="toc-list">
              {parent.children.map((child) => (
                <li class="toc-item">
                  <a href={'#'.concat(child.slug)}>{child.text}</a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))
    }
  </ul>
</nav>

{/* Mobile TOC — collapsible, floats on scroll */}
<aside class="toc-mobile">
  <div class="toc-mobile__title">
    <span>目录</span>
    <svg width="28" height="28" viewBox="0 0 24 24">
      <path
        fill="currentColor"
        d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6l-6-6l1.41-1.41z">
      </path>
    </svg>
  </div>
  <ul class="toc-list">
    {
      tocs.map((parent) => (
        <li class="toc-item">
          <a href={'#'.concat(parent.slug)}>{parent.text}</a>
          {parent.children.length > 0 && (
            <ul class="toc-list">
              {parent.children.map((child) => (
                <li class="toc-item">
                  <a href={'#'.concat(child.slug)}>{child.text}</a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))
    }
  </ul>
</aside>

{/* Desktop: scroll spy + visibility */}
<script>
  const desktopToc = document.querySelector('.toc-desktop') as HTMLElement
  if (!desktopToc) throw new Error('toc-desktop not found')

  const links = desktopToc.querySelectorAll<HTMLAnchorElement>('.toc-item a')
  const articleNode = document.querySelector('.markdown-body') as HTMLElement

  update()
  let raf: number | null
  window.addEventListener('scroll', () => {
    if (raf) return
    raf = requestAnimationFrame(() => {
      update()
      raf = null
    })
  })

  function update() {
    // Show TOC only when article is in view
    const show = articleNode.getBoundingClientRect().top <= 120
    desktopToc.classList.toggle('is-visible', show)

    if (!show) return

    // Update active heading
    let current: HTMLElement | null = null
    for (const link of links) {
      const id = decodeURIComponent(link.hash.slice(1))
      const el = document.getElementById(id)
      if (el && el.getBoundingClientRect().top <= 100) {
        current = el
      } else if (current) {
        break
      }
    }

    const currentId = current?.id ?? ''
    links.forEach((link) => {
      const id = decodeURIComponent(link.hash.slice(1))
      link.classList.toggle('active', id === currentId)
    })
  }
</script>

{/* Mobile: toggle + float on scroll */}
<script>
  const mobileToc = document.querySelector('.toc-mobile') as HTMLElement
  if (!mobileToc) throw new Error('toc-mobile not found')

  const titleNode = mobileToc.querySelector('.toc-mobile__title') as HTMLElement
  const contentNode = document.querySelector('.markdown-body') as HTMLElement

  let scrollThreshold = mobileToc.offsetTop
  let isFloating = false
  let isOpen = false

  titleNode.addEventListener('click', () => {
    isOpen = !isOpen
    mobileToc.classList.toggle('is-open', isOpen)
  })

  let raf: number | null
  window.addEventListener('scroll', () => {
    if (raf) return
    raf = requestAnimationFrame(() => {
      handleScroll()
      raf = null
    })
  })

  window.addEventListener('resize', () => {
    if (!isFloating) {
      scrollThreshold = mobileToc.offsetTop
    }
  })

  function handleScroll() {
    const scrollY = window.scrollY

    if (document.documentElement.offsetWidth >= 1200) return
    if (scrollY > scrollThreshold && !isFloating) {
      contentNode.style.marginTop = `${mobileToc.offsetHeight}px`
      mobileToc.classList.add('is-floating')
      mobileToc.classList.remove('is-open')
      isOpen = false
      isFloating = true
    } else if (scrollY <= scrollThreshold && isFloating) {
      mobileToc.classList.remove('is-floating')
      contentNode.style.marginTop = ''
      isFloating = false
    }
  }
</script>

<style lang="scss" is:global>
/* ===== Desktop TOC ===== */
.toc-desktop {
  display: none;

  @media (min-width: 1200px) {
    display: block;
    position: fixed;
    top: 100px;
    left: calc(50% + 370px);
    width: 200px;
    max-height: calc(100vh - 140px);
    overflow-y: auto;
    border-left: 2px solid var(--x-border);
    color: var(--x-font-sub);
    font-size: 0.8rem;
    opacity: 0;
    transition: opacity 0.2s;

    &.is-visible {
      opacity: 1;
    }

    &::-webkit-scrollbar {
      width: 3px;
      background-color: transparent;
    }

    &::-webkit-scrollbar-thumb {
      background-color: var(--x-border);
      border-radius: 3px;
    }
  }
}

.toc-desktop__title {
  margin: 0 0 8px;
  padding-left: 14px;
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--x-font-sub);
  opacity: 0.7;
}

/* ===== Mobile TOC ===== */
.toc-mobile {
  display: block;
  border: 1px solid var(--x-border);
  border-radius: 6px;
  color: var(--x-font-sub);
  font-size: 0.875rem;
  background-color: var(--x-bg);
  z-index: 10;

  @media (min-width: 1200px) {
    display: none;
  }

  > .toc-list {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  &.is-open > .toc-list {
    max-height: 220px;
    padding-bottom: 12px;
    overflow-y: auto;
  }

  &.is-floating {
    position: fixed;
    right: 0;
    top: 64px;
    border-radius: 6px 0 0 6px;
    border-right: none;
    transform: translateX(12px);
    opacity: 0.3;
    transition: transform 0.2s, opacity 0.2s;

    > .toc-list {
      display: none;
    }

    .toc-mobile__title {
      padding: 6px;
      padding-left: 0;

      span { display: none; }

      svg { transform: rotate(90deg); }
    }

    &:hover {
      opacity: 1;
      transform: translateX(0);

      .toc-mobile__title {
        padding-left: 6px;
      }
    }

    &.is-open {
      opacity: 1;
      transform: translateX(0);

      > .toc-list {
        display: block;
        max-height: 86vh;
        padding-bottom: 12px;
        overflow-y: auto;
      }

      .toc-mobile__title span { display: inline; }
      .toc-mobile__title svg { transform: rotate(180deg); }
    }
  }
}

.toc-mobile__title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 6px 16px;
  font-weight: bold;
  cursor: pointer;

  svg {
    transition: transform 0.2s;
  }
}

.is-open > .toc-mobile__title svg {
  transform: rotate(180deg);
}

/* ===== Shared ===== */
.toc-list {
  list-style: none;
  margin: 0;
  padding: 0;

  .toc-list {
    padding-left: 10px;
    font-size: 0.9em;
  }
}

.toc-item a {
  display: block;
  padding: 3px 12px;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  transition: color 0.2s, border-color 0.2s;

  &:hover {
    color: var(--x-font);
  }

  &.active {
    color: var(--x-primary);
    font-weight: 500;
  }
}
</style>
