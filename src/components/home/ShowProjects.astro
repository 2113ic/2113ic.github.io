---
import HeadLine from './HeadLine.astro'
import config from '@config'

const projects = config.projects ?? []
---

<div class="projects">
  <HeadLine more="https://github.com/2113ic">Projects</HeadLine>

  <div class="content">
    {
      projects.map((project) => {
        return (
          <a class="project" href={project.url} target="_blank">
            <div class="icon" set:html={project.icon} />
            <div class="info">
              <div class="title">{project.title}</div>
              <div class="summary">{project.summary}</div>
            </div>
          </a>
        )
      })
    }
  </div>
</div>

<style lang="scss">
.icon {
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
  width: 36px;
  height: 36px;
  margin-right: 12px;
  font-size: 0;

  :global(svg) {
    width: 100%;
    height: 100%;
  }
}

.title {
  line-height: 28px;
}

.summary {
  color: var(--x-font-sub);
  font-size: 0.875rem;
}

.content {
  display: grid;
  grid-gap: 1rem;
  gap: 1rem;
  grid-template-columns: repeat(1, minmax(0, 1fr));
  margin-bottom: 24px;

  .project {
    display: flex;
    align-items: center;
    padding: 16px;
    border-radius: 10px;
    background-color: var(--x-bg-card);
    box-shadow: var(--x-card-shadow);
    transition: transform 0.2s, box-shadow 0.2s;

    &:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(99, 102, 241, 0.1);
    }
  }
}

@media (min-width: 640px) {
  .content {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}
</style>
