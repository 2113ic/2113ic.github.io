---
import HeadLine from './HeadLine.astro'
import { getCollection } from 'astro:content'
import config from '@config'

const isProd = import.meta.env.PROD
const isNotDraft = ({ data }) => isProd ? data.draft === false : true
const posts = await getCollection('Posts', isNotDraft)
const { showNum } = config.blogs

const sortedBlogs = posts.sort((a, b) => {
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
})

const showBlogs = sortedBlogs.slice(0, showNum)
---

<div class="blogs">
  { showBlogs.length !== 0 && <HeadLine more="./blogs">Blogs</HeadLine> }

  <div class="content">
    {
      showBlogs.map(({ data, id }) => (
        <a href={`./posts/${id}`}>
          <span>{data.title}</span>
          <time class="time">{data.date}</time>
        </a>
      ))
    }
  </div>
</div>

<style lang="scss">
.content {
  margin-bottom: 24px;

  a {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 14px 16px;
    margin: 4px 0;
    border-radius: 8px;
    font-size: 1.05rem;
    cursor: pointer;
    overflow: hidden;
    transition: background-color 0.2s, transform 0.2s;

    &:hover {
      background-color: var(--x-hover);
      transform: translateX(4px);
    }
  }

  .time {
    flex-shrink: 0;
    margin-left: 16px;
    color: var(--x-font-sub);
    font-family: var(--x-font-mono);
    font-size: 0.85rem;
  }
}
</style>
