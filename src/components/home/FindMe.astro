---
import config from '@config'

const findmeList = config.findme ?? []
---

<ul class="find-me">
  {
    findmeList.map((item) => (
      <li style={item.background ? `background-color: ${item.background}` : undefined}>
        <a href={item.url}>
          <div class="icon" set:html={item.icon} />
          {item.label && <div class="text">{item.label}</div>}
        </a>
      </li>
    ))
  }
</ul>

<style lang="scss">
.find-me {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  padding: 0;
  margin-top: 16px;
  list-style: none;

  li {
    padding: 8px 16px;
    border-radius: 8px;
    background-color: var(--x-bg-card);
    box-shadow: var(--x-card-shadow);
    transition: transform 0.2s;

    &:hover {
      transform: translateY(-1px);
    }
  }

  a {
    display: flex;
    justify-content: center;
    align-items: center;
  }
}

.icon {
  width: 20px;
  height: 20px;
  font-size: 0;
}

.text {
  margin-left: 6px;
  font-family: var(--x-font-heading);
  font-size: 14px;
  font-weight: 500;
}
</style>
