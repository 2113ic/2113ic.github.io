---
import DefaultLayout from "@layout/DefaultLayout.astro";
import ToolBar from "@comp/ToolBar.astro";
import Toc from "@comp/blog/Toc.astro";

import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";

// Styles
import "@style/markdown.scss";

interface Props {
  entry: CollectionEntry<"Posts">;
}

export async function getStaticPaths() {
  const posts = await getCollection("Posts");

  return posts.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const { title, date, tags, desc } = entry.data;
---

<DefaultLayout title={title} description={desc}>
  <ToolBar />
  <div class="wrapper">
    <a class="back-link" href="/blogs">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M19 12H5M12 19l-7-7 7-7"/>
      </svg>
      返回文章列表
    </a>

    <div class="post-layout">
      <Toc data={headings} />

      <article class="markdown-body">
        <h1>{title}</h1>
        <div class="mate-wrapper">
          <p class="date">最后修改：{date}</p>
          {tags.map((tag: string) => <a class="tag">{tag}</a>)}
        </div>
        <Content />
      </article>
    </div>
  </div>
</DefaultLayout>

<style lang="scss">
.back-link {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 16px;
  color: var(--x-font-sub);
  font-size: 14px;
  transition: color 0.2s;

  &:hover {
    color: var(--x-primary);
  }
}

.wrapper {
  --post-width: 800px;
  --toc-width: 200px;
  --toc-gap: 20px;

  max-width: var(--post-width);
  margin: 0 auto;
  padding: 0 32px 64px;

  @media (max-width: 768px) {
    padding: 32px 24px;
  }
}

.post-layout {
  position: relative;

  .markdown-body {
    overflow: hidden;
  }
}

.mate-wrapper {
  display: flex;
  align-items: center;
  padding-bottom: 16px;
  font-size: 12px;
  color: var(--x-font-sub);
  overflow: hidden;

  .date {
    margin: 0;
    margin-right: 24px;
  }

  .tag {
    margin-right: 12px;
    padding: 4px 0;
    text-transform: uppercase;
    border-bottom: 1px dashed var(--x-border);
    transition: all 0.2s;
    cursor: pointer;

    &:first-of-type {
      margin-left: 0;
    }

    &:hover {
      color: var(--x-primary);
      border-bottom: 1px solid;
    }
  }
}
</style>
