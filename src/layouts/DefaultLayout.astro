---
import '@style/index.scss'
import config from '@config'

const { title, description } = Astro.props
const pageTitle = title ? `${title} | ${config.title}` : config.title
const pageDesc = description || '恶龙的咆哮~'
const canonicalURL = new URL(Astro.url.pathname, Astro.site)
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="keywords" content="默小言的空间, 2113ic, 前端" />
  <meta name="description" content={pageDesc} />
  <meta name="author" content="默小言 | 2113ic" />

  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDesc} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:site_name" content={config.title} />

  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={pageDesc} />

  <link rel="canonical" href={canonicalURL} />
  <link rel="icon" href="/logo.png" type="image/png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <title>{pageTitle}</title>

  <script is:inline>
    ;(function initTheme() {
      const html = document.documentElement
      const storedTheme = localStorage.getItem('theme')
      const systemTheme = window.matchMedia(
        '(prefers-color-scheme: dark)'
      ).matches
      const applyTheme = storedTheme || (systemTheme ? 'dark' : 'light')

      localStorage.setItem('theme', applyTheme)
      html.setAttribute('data-theme', applyTheme)
    })()
  </script>
</head>
<body>
  <slot />
</body>
</html>
